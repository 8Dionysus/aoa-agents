{
  "schema_version": "aoa-local-kag-manifest-v1",
  "repo": "aoa-agents",
  "owner_surface": "kag/AGENTS.md",
  "source_surfaces": [
    {
      "repo": "aoa-agents",
      "path": "agents/source_home.manifest.json",
      "source_class": "agent_source",
      "role": "primary",
      "authority": "authored_source"
    },
    {
      "repo": "aoa-agents",
      "path": "agents/README.md",
      "source_class": "agent_source",
      "role": "owner_route",
      "authority": "authored_source"
    },
    {
      "repo": "aoa-agents",
      "path": "generated/agent_registry.min.json",
      "source_class": "agent_source",
      "role": "supporting",
      "authority": "derived_readmodel"
    },
    {
      "repo": "aoa-agents",
      "path": "generated/capability_pack_registry.min.json",
      "source_class": "agent_source",
      "role": "supporting",
      "authority": "derived_readmodel"
    }
  ],
  "record_classes": [
    "node",
    "edge",
    "index",
    "projection",
    "receipt"
  ],
  "storage_posture": {
    "git_surface": "portable_records",
    "payload_class": "manifest",
    "runtime_route": "source-repo"
  },
  "validation_routes": [
    {
      "route": "scripts/validate_agent_source_home.py",
      "lane": "owner-local"
    }
  ],
  "consumer_routes": [
    "aoa-kag registry",
    "abyss-stack federation mirror",
    "aoa-kag-mcp resource"
  ],
  "owner_return_routes": [
    {
      "repo": "aoa-agents",
      "surface": "agents/README.md",
      "route_kind": "authored_meaning"
    }
  ]
}
