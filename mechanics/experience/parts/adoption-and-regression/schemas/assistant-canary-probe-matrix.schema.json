{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "assistant_canary_probe_matrix",
  "type": "object",
  "description": "assistant_canary_probe_matrix schema for AoA experience deployment watchtower v0.5.",
  "required": [
    "matrix_id",
    "assistant_id",
    "version",
    "probes",
    "required_pass_rate"
  ],
  "properties": {
    "matrix_id": {
      "type": "string"
    },
    "assistant_id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "probes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "probe_id"
        ],
        "properties": {
          "probe_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "required_pass_rate": {
      "type": "number"
    }
  },
  "additionalProperties": false
}
