{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/schemas/recursor-role-contract.v1.schema.json",
  "title": "Recursor Role Contract v1",
  "type": "object",
  "required": [
    "schema_version",
    "recursor_id",
    "owner_repo",
    "readiness_status",
    "default_form",
    "future_agonic_candidate",
    "allowed_inputs",
    "allowed_outputs",
    "forbidden_actions",
    "memory_policy",
    "codex_projection",
    "receipts_required",
    "stop_lines"
  ],
  "properties": {
    "schema_version": {
      "const": "recursor-role-contract/v1"
    },
    "recursor_id": {
      "type": "string",
      "pattern": "^recursor\\.(witness|executor)$"
    },
    "owner_repo": {
      "const": "aoa-agents"
    },
    "readiness_status": {
      "const": "candidate"
    },
    "default_form": {
      "type": "object",
      "required": [
        "kind",
        "base_role_gravity",
        "service_offices",
        "arena_eligible"
      ],
      "properties": {
        "kind": {
          "enum": [
            "assistant"
          ]
        },
        "base_role_gravity": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "service_offices": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "arena_eligible": {
          "const": false
        }
      },
      "additionalProperties": true
    },
    "future_agonic_candidate": {
      "type": "object",
      "required": [
        "enabled",
        "candidate_seats",
        "live_authority"
      ],
      "properties": {
        "enabled": {
          "const": false
        },
        "candidate_seats": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "live_authority": {
          "const": false
        }
      },
      "additionalProperties": true
    },
    "allowed_inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_actions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "allOf": [
        {
          "contains": {
            "const": "spawn_agent"
          }
        },
        {
          "contains": {
            "const": "open_arena_session"
          }
        },
        {
          "contains": {
            "const": "issue_verdict"
          }
        },
        {
          "contains": {
            "const": "write_scar"
          }
        },
        {
          "contains": {
            "const": "mutate_rank"
          }
        },
        {
          "contains": {
            "const": "promote_to_tree_of_sophia"
          }
        },
        {
          "contains": {
            "const": "hidden_scheduler_action"
          }
        }
      ]
    },
    "memory_policy": {
      "type": "object",
      "required": [
        "direct_durable_write_allowed",
        "may_prepare_memo_candidate",
        "memo_owner_repo"
      ],
      "properties": {
        "direct_durable_write_allowed": {
          "const": false
        },
        "may_prepare_memo_candidate": {
          "type": "boolean"
        },
        "memo_owner_repo": {
          "const": "aoa-memo"
        }
      },
      "additionalProperties": true
    },
    "codex_projection": {
      "type": "object",
      "required": [
        "status",
        "install_by_default",
        "requires_owner_review"
      ],
      "properties": {
        "status": {
          "const": "candidate_only"
        },
        "install_by_default": {
          "const": false
        },
        "requires_owner_review": {
          "const": true
        }
      },
      "additionalProperties": true
    },
    "receipts_required": {
      "const": true
    },
    "stop_lines": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "allOf": [
        {
          "contains": {
            "const": "projection_candidate_is_not_install"
          }
        },
        {
          "contains": {
            "const": "assistant_is_not_contestant"
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "recursor_id": {
            "const": "recursor.witness"
          }
        },
        "required": [
          "recursor_id"
        ]
      },
      "then": {
        "properties": {
          "forbidden_actions": {
            "allOf": [
              {
                "contains": {
                  "const": "close_review_decision"
                }
              },
              {
                "contains": {
                  "const": "apply_patch"
                }
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "recursor_id": {
            "const": "recursor.executor"
          }
        },
        "required": [
          "recursor_id"
        ]
      },
      "then": {
        "properties": {
          "forbidden_actions": {
            "allOf": [
              {
                "contains": {
                  "const": "execute_without_approved_plan"
                }
              },
              {
                "contains": {
                  "const": "self_verify_final_truth"
                }
              }
            ]
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
