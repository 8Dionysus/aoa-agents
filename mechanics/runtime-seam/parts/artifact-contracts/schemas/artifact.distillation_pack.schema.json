{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-agents/main/schemas/artifact.distillation_pack.schema.json",
  "title": "AoA distillation pack artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "summaries",
    "entities",
    "decisions",
    "memory_candidates"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "distillation_pack"
    },
    "summaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "memory_candidates": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
