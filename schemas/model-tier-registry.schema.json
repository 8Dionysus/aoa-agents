{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-agents/schemas/model-tier-registry.schema.json",
  "title": "AoA model-tier registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "layer",
    "model_tiers"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "layer": {
      "type": "string",
      "const": "aoa-agents"
    },
    "model_tiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status",
          "summary",
          "primary_duty",
          "output_contract",
          "default_memory_scope",
          "handoff_targets",
          "artifact_requirement"
        ],
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "router",
              "planner",
              "executor",
              "verifier",
              "conductor",
              "deep",
              "archivist"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "planned",
              "experimental",
              "deprecated"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 10
          },
          "primary_duty": {
            "type": "string",
            "minLength": 3
          },
          "output_contract": {
            "type": "string",
            "minLength": 5
          },
          "default_memory_scope": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "core",
                "selected_hot",
                "selected_warm",
                "selected_cool",
                "selected_cold",
                "selected_frozen"
              ]
            },
            "uniqueItems": true
          },
          "handoff_targets": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 2
            },
            "uniqueItems": true
          },
          "artifact_requirement": {
            "type": "string",
            "minLength": 3
          },
          "activation_conditions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 3
            },
            "uniqueItems": true
          }
        }
      }
    }
  }
}
