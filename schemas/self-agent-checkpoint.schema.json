{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-agents/main/schemas/self-agent-checkpoint.schema.json",
  "title": "AoA self-agent checkpoint contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "role",
    "alignment_profile",
    "sandbox",
    "memory_scope",
    "audit_policy",
    "approval_mode",
    "rollback_marker",
    "health_check",
    "max_iterations"
  ],
  "properties": {
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "alignment_profile": {
      "type": "string",
      "minLength": 1
    },
    "sandbox": {
      "type": "string",
      "minLength": 1
    },
    "memory_scope": {
      "type": "string",
      "minLength": 1
    },
    "audit_policy": {
      "type": "string",
      "minLength": 1
    },
    "approval_mode": {
      "type": "string",
      "enum": [
        "required",
        "conditional",
        "advisory"
      ]
    },
    "rollback_marker": {
      "type": "string",
      "minLength": 1
    },
    "health_check": {
      "type": "string",
      "minLength": 1
    },
    "max_iterations": {
      "type": "integer",
      "minimum": 1
    }
  }
}
