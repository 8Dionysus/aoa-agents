{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-agents/schemas/agent-source-home.schema.json",
  "title": "AoA agent source home manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "owner_repo",
    "home",
    "role",
    "home_rules",
    "branches",
    "stronger_owner_routes",
    "families"
  ],
  "properties": {
    "$schema": {
      "const": "https://aoa-agents/schemas/agent-source-home.schema.json"
    },
    "schema_version": {
      "const": "agent_source_home_v1"
    },
    "owner_repo": {
      "const": "aoa-agents"
    },
    "home": {
      "const": "agents/"
    },
    "role": {
      "type": "string",
      "minLength": 20
    },
    "home_rules": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 20
      }
    },
    "branches": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/branch"
      }
    },
    "stronger_owner_routes": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pressure",
          "route"
        ],
        "properties": {
          "pressure": {
            "type": "string",
            "minLength": 5
          },
          "route": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "families": {
      "type": "array",
      "minItems": 6,
      "items": {
        "$ref": "#/$defs/family"
      }
    }
  },
  "$defs": {
    "repo_path": {
      "type": "string",
      "minLength": 3,
      "pattern": "^[A-Za-z0-9._*/ -]+$"
    },
    "branch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "role",
        "families",
        "owner_surface",
        "stop_lines"
      ],
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "role_houses",
            "operating_model"
          ]
        },
        "path": {
          "$ref": "#/$defs/repo_path"
        },
        "role": {
          "type": "string",
          "minLength": 20
        },
        "families": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "base_profiles",
              "profile_adjuncts",
              "model_tiers",
              "orchestrator_classes",
              "cohort_patterns",
              "runtime_seam_bindings"
            ]
          }
        },
        "owner_surface": {
          "$ref": "#/$defs/repo_path"
        },
        "stop_lines": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    "family": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "object_pattern",
        "source_kind",
        "meaning",
        "owner_surface",
        "schema_refs",
        "publishes_to",
        "builders",
        "validators",
        "reader_routes",
        "stop_lines"
      ],
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "base_profiles",
            "profile_adjuncts",
            "model_tiers",
            "orchestrator_classes",
            "cohort_patterns",
            "runtime_seam_bindings"
          ]
        },
        "path": {
          "$ref": "#/$defs/repo_path"
        },
        "object_pattern": {
          "type": "string",
          "minLength": 3
        },
        "source_kind": {
          "type": "string",
          "enum": [
            "role_contract",
            "role_companion",
            "effort_tier",
            "orchestrator_class",
            "cohort_pattern",
            "runtime_seam_binding"
          ]
        },
        "meaning": {
          "type": "string",
          "minLength": 30
        },
        "owner_surface": {
          "$ref": "#/$defs/repo_path"
        },
        "schema_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/repo_path"
          }
        },
        "publishes_to": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/repo_path"
          }
        },
        "builders": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/repo_path"
          }
        },
        "validators": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/repo_path"
          }
        },
        "reader_routes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/repo_path"
          }
        },
        "stop_lines": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    }
  }
}
