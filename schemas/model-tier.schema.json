{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-agents/schemas/model-tier.schema.json",
  "title": "AoA model tier",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "id",
    "status",
    "summary",
    "primary_duty",
    "output_contract",
    "default_memory_scope",
    "handoff_targets",
    "artifact_requirement",
    "activation_conditions"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://aoa-agents/schemas/model-tier.schema.json"
    },
    "id": {
      "type": "string",
      "enum": [
        "router",
        "planner",
        "executor",
        "verifier",
        "conductor",
        "deep",
        "archivist"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "planned",
        "experimental",
        "deprecated"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 10
    },
    "primary_duty": {
      "type": "string",
      "minLength": 3
    },
    "output_contract": {
      "type": "string",
      "minLength": 5
    },
    "default_memory_scope": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "core",
          "selected_hot",
          "selected_warm",
          "selected_cool",
          "selected_cold",
          "selected_frozen"
        ]
      }
    },
    "handoff_targets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "artifact_requirement": {
      "type": "string",
      "minLength": 3
    },
    "activation_conditions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 3
      }
    }
  }
}
