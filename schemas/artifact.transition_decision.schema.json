{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-agents/main/schemas/artifact.transition_decision.schema.json",
  "title": "AoA transition decision artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "decision",
    "reason",
    "next_hop"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "transition_decision"
    },
    "decision": {
      "type": "string",
      "minLength": 3
    },
    "reason": {
      "type": "string",
      "minLength": 5
    },
    "next_hop": {
      "type": "string",
      "minLength": 2
    }
  }
}
