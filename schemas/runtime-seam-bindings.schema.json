{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-agents/main/schemas/runtime-seam-bindings.schema.json",
  "title": "AoA runtime seam bindings",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "layer",
    "bindings"
  ],
  "properties": {
    "version": {
      "type": "integer"
    },
    "layer": {
      "type": "string",
      "const": "aoa-agents"
    },
    "bindings": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "phase",
          "tier_id",
          "role_names",
          "artifact_type"
        ],
        "properties": {
          "phase": {
            "type": "string",
            "enum": [
              "route",
              "plan",
              "do",
              "verify",
              "transition",
              "deep",
              "distill"
            ]
          },
          "tier_id": {
            "type": "string",
            "minLength": 2
          },
          "role_names": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 2
            }
          },
          "artifact_type": {
            "type": "string",
            "enum": [
              "route_decision",
              "bounded_plan",
              "work_result",
              "verification_result",
              "transition_decision",
              "deep_synthesis_note",
              "distillation_pack"
            ]
          }
        }
      }
    }
  }
}
