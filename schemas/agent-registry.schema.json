{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-agents/schemas/agent-registry.schema.json",
  "title": "AoA agent registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "layer", "agents"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "layer": {
      "type": "string",
      "const": "aoa-agents"
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "role",
          "status",
          "summary",
          "preferred_skill_families",
          "memory_posture",
          "evaluation_posture",
          "handoff_rule"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 3
          },
          "name": {
            "type": "string",
            "minLength": 3
          },
          "role": {
            "type": "string",
            "minLength": 3
          },
          "status": {
            "type": "string",
            "enum": ["active", "planned", "experimental", "deprecated"]
          },
          "summary": {
            "type": "string",
            "minLength": 10
          },
          "preferred_skill_families": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 2
            }
          },
          "memory_posture": {
            "type": "string",
            "enum": ["none", "light_recall", "bounded_recall", "deep_recall"]
          },
          "evaluation_posture": {
            "type": "string",
            "enum": ["minimal", "required", "strict", "paired_eval"]
          },
          "handoff_rule": {
            "type": "string",
            "enum": ["solo_ok", "handoff_on_ambiguity", "handoff_on_risk", "review_required"]
          }
        }
      }
    }
  }
}
