{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-agents/schemas/agent-registry.schema.json",
  "title": "AoA agent registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "layer", "artifact_identity", "agents"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 2
    },
    "layer": {
      "type": "string",
      "const": "aoa-agents"
    },
    "artifact_identity": {
      "type": "object",
      "required": [
        "artifact_class",
        "surface_state",
        "owner_repo",
        "authority_ref",
        "producer",
        "consumer_expectation",
        "privacy_boundary",
        "content_identity",
        "abi_epoch",
        "contract_version",
        "trust_layer",
        "verification",
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "artifact_class": { "type": "string", "minLength": 3 },
        "surface_state": { "type": "string", "minLength": 3 },
        "owner_repo": { "type": "string", "const": "aoa-agents" },
        "authority_ref": { "type": "string", "minLength": 3 },
        "producer": { "type": "string", "minLength": 3 },
        "consumer_expectation": { "type": "string", "minLength": 3 },
        "privacy_boundary": { "type": "string", "minLength": 3 },
        "content_identity": { "type": "string", "minLength": 3 },
        "abi_epoch": { "type": "string", "minLength": 3 },
        "contract_version": { "type": "string", "minLength": 3 },
        "trust_layer": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "abi_contract_signature",
              "local_provenance",
              "w3c_prov_lineage",
              "slsa_in_toto",
              "sbom",
              "ml_bom",
              "sigstore_cosign",
              "c2pa",
              "tuf",
              "scitt"
            ]
          }
        },
        "verification": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 3 } },
        "action": {
          "type": "string",
          "enum": [
            "KEEP",
            "DEFINE_ABI",
            "ADD_CONTRACT_SIGNATURE",
            "ADD_LOCAL_PROVENANCE",
            "ADD_CONSUMER_EXPECTATION",
            "HARDEN_VALIDATOR",
            "ADD_TEST",
            "ADD_RELEASE_PROVENANCE",
            "ADD_BOM",
            "ADD_ML_BOM",
            "ADD_COSIGN",
            "ADD_C2PA",
            "PREPARE_TUF",
            "PREPARE_SCITT",
            "ROUTE_TO_OWNER",
            "DEFER_WITH_RATIONALE"
          ]
        }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "role",
          "status",
          "summary",
          "preferred_skill_families",
          "memory_posture",
          "memory_rights",
          "evaluation_posture",
          "handoff_rule"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 3
          },
          "name": {
            "type": "string",
            "minLength": 3
          },
          "role": {
            "type": "string",
            "minLength": 3
          },
          "status": {
            "type": "string",
            "enum": ["active", "planned", "experimental", "deprecated"]
          },
          "summary": {
            "type": "string",
            "minLength": 10
          },
          "preferred_skill_families": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 2
            }
          },
          "memory_posture": {
            "type": "string",
            "enum": ["none", "light_recall", "bounded_recall", "deep_recall"]
          },
          "memory_rights": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "default_read_bands",
              "default_write_bands",
              "allowed_recall_scopes",
              "promotion_rights",
              "freeze_rights"
            ],
            "properties": {
              "default_read_bands": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "enum": ["core", "hot", "warm", "cool", "cold", "frozen"]
                }
              },
              "default_write_bands": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "enum": ["core", "hot", "warm", "cool", "cold", "frozen"]
                }
              },
              "allowed_recall_scopes": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "enum": ["thread", "session", "repo", "project", "workspace", "ecosystem"]
                }
              },
              "promotion_rights": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "can_nominate",
                  "can_confirm",
                  "can_promote",
                  "can_demote",
                  "can_retire",
                  "can_rescue",
                  "allowed_transitions"
                ],
                "properties": {
                  "can_nominate": { "type": "boolean" },
                  "can_confirm": { "type": "boolean" },
                  "can_promote": { "type": "boolean" },
                  "can_demote": { "type": "boolean" },
                  "can_retire": { "type": "boolean" },
                  "can_rescue": { "type": "boolean" },
                  "allowed_transitions": {
                    "type": "array",
                    "uniqueItems": true,
                    "items": {
                      "type": "string",
                      "enum": [
                        "hot_to_warm",
                        "warm_to_cool",
                        "cool_to_cold",
                        "cold_to_cool"
                      ]
                    }
                  }
                }
              },
              "freeze_rights": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "can_recommend",
                  "can_prepare",
                  "can_finalize"
                ],
                "properties": {
                  "can_recommend": { "type": "boolean" },
                  "can_prepare": { "type": "boolean" },
                  "can_finalize": { "type": "boolean" }
                }
              }
            }
          },
          "evaluation_posture": {
            "type": "string",
            "enum": ["minimal", "required", "strict", "paired_eval"]
          },
          "handoff_rule": {
            "type": "string",
            "enum": ["solo_ok", "handoff_on_ambiguity", "handoff_on_risk", "review_required"]
          }
        }
      }
    }
  }
}
