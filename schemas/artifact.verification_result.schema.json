{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-agents/main/schemas/artifact.verification_result.schema.json",
  "title": "AoA verification result artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "verdict",
    "checked_artifacts",
    "summary"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "verification_result"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "ambiguity",
        "escalate"
      ]
    },
    "checked_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "summary": {
      "type": "string",
      "minLength": 10
    }
  }
}
