{
  "version": 1,
  "layer": "aoa-agents",
  "family": "capability_packs",
  "capability_packs": [
    {
      "id": "memo-writeback.write-candidate",
      "status": "experimental",
      "summary": "Memory writeback stewardship limited to local candidates and provenance checks.",
      "permission_posture": {
        "default_mode": "write-candidate-only",
        "mutation_allowed": true,
        "requires_gate": true,
        "notes": [
          "May write only repo-local memo candidate surfaces when the repo owns such a port.",
          "Durable reviewed memory remains owned by aoa-memo."
        ]
      },
      "tool_refs": [
        "rg:provenance-scan",
        "git:diff-log-readonly",
        "apply_patch:memo-candidate-only"
      ],
      "skill_refs": [
        "aoa-source-of-truth-check",
        "aoa-bounded-context-map"
      ],
      "technique_refs": [
        "aoa-techniques:memory-writeback-check",
        "aoa-techniques:provenance-preservation"
      ],
      "memory_routes": {
        "read_refs": [
          "aoa-memo:brief",
          "aoa-session-memory:search-readonly"
        ],
        "write_refs": [
          "memo/candidates:write-candidate"
        ],
        "owner": "aoa-memo"
      },
      "proof_routes": [
        "scripts/validate_agents.py",
        "scripts/validate_agent_source_home.py"
      ],
      "projection_hints": [
        "Suitable for memory-keeper specializations that prepare handoff candidates.",
        "Projection must not grant durable memo promotion rights by default."
      ],
      "owner_boundaries": [
        {
          "pressure": "durable memory canon",
          "route": "aoa-memo"
        },
        {
          "pressure": "session evidence repair or reindexing",
          "route": ".aoa"
        }
      ],
      "stop_lines": [
        "Do not promote, demote, retire, or rewrite durable memory truth through this pack.",
        "Do not write outside the repo-local memory candidate surface."
      ],
      "source_path": "agents/operating-model/capabilities/packs/memo-writeback.write-candidate.capability.json"
    },
    {
      "id": "release-readiness.readonly",
      "status": "experimental",
      "summary": "Read-only release readiness evaluation for agent-layer source and readers.",
      "permission_posture": {
        "default_mode": "read-only",
        "mutation_allowed": false,
        "requires_gate": false,
        "notes": [
          "May run release checks and inspect artifacts.",
          "Must hand off if readiness requires source mutation."
        ]
      },
      "tool_refs": [
        "python:release-check",
        "git:diff-status-readonly",
        "rg:proof-surface-scan"
      ],
      "skill_refs": [
        "aoa-invariant-coverage-audit",
        "aoa-contract-test",
        "aoa-source-of-truth-check"
      ],
      "technique_refs": [
        "aoa-techniques:release-readiness",
        "aoa-techniques:evidence-led-closeout"
      ],
      "memory_routes": {
        "read_refs": [
          "aoa-memo:brief"
        ],
        "write_refs": [],
        "owner": "aoa-memo"
      },
      "proof_routes": [
        "scripts/release_check.py",
        "scripts/validate_agents.py",
        "python -m unittest discover -s tests -p 'test_*.py'"
      ],
      "projection_hints": [
        "Suitable for evaluator specializations that score readiness without editing.",
        "Projection should prefer validation and evidence tools over write tools."
      ],
      "owner_boundaries": [
        {
          "pressure": "proof rubric or verdict canon",
          "route": "aoa-evals"
        },
        {
          "pressure": "implementation fix",
          "route": "coder.repo-refactor"
        }
      ],
      "stop_lines": [
        "Do not change source state through this pack.",
        "Do not promote local readiness judgment into eval doctrine."
      ],
      "source_path": "agents/operating-model/capabilities/packs/release-readiness.readonly.capability.json"
    },
    {
      "id": "repo-refactor.workspace-write",
      "status": "experimental",
      "summary": "Repo-local refactor execution with explicit gates, builders, and validators.",
      "permission_posture": {
        "default_mode": "workspace-write",
        "mutation_allowed": true,
        "requires_gate": true,
        "notes": [
          "Mutation must be repo-local and tied to a named owner surface.",
          "Runtime, service, secret, plugin, hook, and network posture changes need a stronger gate before use."
        ]
      },
      "tool_refs": [
        "apply_patch:repo-local-edits",
        "rg:source-search",
        "git:status-diff-add-commit",
        "python:builders-and-validators"
      ],
      "skill_refs": [
        "aoa-change-protocol",
        "aoa-bounded-context-map",
        "aoa-adr-write",
        "aoa-source-of-truth-check"
      ],
      "technique_refs": [
        "aoa-techniques:bounded-refactor",
        "aoa-techniques:generated-from-source",
        "aoa-techniques:validator-first-closeout"
      ],
      "memory_routes": {
        "read_refs": [
          "aoa-memo:brief",
          "aoa-session-memory:search-readonly"
        ],
        "write_refs": [
          "memo/candidates:write-candidate"
        ],
        "owner": "aoa-memo"
      },
      "proof_routes": [
        "scripts/build_published_surfaces.py",
        "scripts/validate_agent_source_home.py",
        "scripts/validate_agents.py",
        "scripts/release_check.py"
      ],
      "projection_hints": [
        "Suitable for coder specializations that land repo-local changes.",
        "Projection must keep mutation authority narrower than runtime or infrastructure authority."
      ],
      "owner_boundaries": [
        {
          "pressure": "workflow implementation",
          "route": "aoa-skills"
        },
        {
          "pressure": "runtime behavior",
          "route": "abyss-stack"
        },
        {
          "pressure": "proof doctrine",
          "route": "aoa-evals"
        }
      ],
      "stop_lines": [
        "Do not use this pack for service, runtime, network, secret, or plugin mutation without a stronger route.",
        "Do not treat generated reader edits as source truth."
      ],
      "source_path": "agents/operating-model/capabilities/packs/repo-refactor.workspace-write.capability.json"
    },
    {
      "id": "route-drift-review.readonly",
      "status": "experimental",
      "summary": "Read-only review of route drift, owner mismatch, and generated/source divergence.",
      "permission_posture": {
        "default_mode": "read-only",
        "mutation_allowed": false,
        "requires_gate": false,
        "notes": [
          "May run validators and inspect diffs.",
          "Must return findings or hand off to a workspace-write specialization for fixes."
        ]
      },
      "tool_refs": [
        "git:diff-log-status-readonly",
        "rg:legacy-name-scan",
        "python:validators-readonly"
      ],
      "skill_refs": [
        "aoa-invariant-coverage-audit",
        "aoa-source-of-truth-check",
        "aoa-bounded-context-map"
      ],
      "technique_refs": [
        "aoa-techniques:drift-audit",
        "aoa-techniques:owner-route-review"
      ],
      "memory_routes": {
        "read_refs": [
          "aoa-memo:brief",
          "aoa-session-memory:search-readonly"
        ],
        "write_refs": [],
        "owner": "aoa-memo"
      },
      "proof_routes": [
        "scripts/validate_agent_source_home.py",
        "scripts/validate_agents.py",
        "git diff --check"
      ],
      "projection_hints": [
        "Suitable for reviewer specializations that inspect without fixing.",
        "Projection may expose read-only git and validation commands."
      ],
      "owner_boundaries": [
        {
          "pressure": "implementation fix",
          "route": "coder.repo-refactor"
        },
        {
          "pressure": "formal proof verdict",
          "route": "aoa-evals"
        }
      ],
      "stop_lines": [
        "Do not land fixes through this read-only pack.",
        "Do not treat a review finding as durable memory canon."
      ],
      "source_path": "agents/operating-model/capabilities/packs/route-drift-review.readonly.capability.json"
    },
    {
      "id": "topology-readonly",
      "status": "experimental",
      "summary": "Read-only topology and boundary stewardship for source-owner decisions.",
      "permission_posture": {
        "default_mode": "read-only",
        "mutation_allowed": false,
        "requires_gate": false,
        "notes": [
          "May inspect source, generated readers, decisions, and sibling owner cards.",
          "Must hand off before editing schemas, validators, generated surfaces, or source objects."
        ]
      },
      "tool_refs": [
        "rg:source-search",
        "git:status-log-diff-readonly",
        "python:validators-readonly"
      ],
      "skill_refs": [
        "aoa-bounded-context-map",
        "aoa-source-of-truth-check"
      ],
      "technique_refs": [
        "aoa-techniques:boundary-map",
        "aoa-techniques:source-before-summary"
      ],
      "memory_routes": {
        "read_refs": [
          "aoa-memo:brief",
          "aoa-session-memory:search-readonly"
        ],
        "write_refs": [],
        "owner": "aoa-memo"
      },
      "proof_routes": [
        "scripts/validate_agent_source_home.py",
        "scripts/validate_nested_agents.py"
      ],
      "projection_hints": [
        "Suitable for read-only architect specializations.",
        "Projection may expose search and validation tools but no write tools."
      ],
      "owner_boundaries": [
        {
          "pressure": "durable architecture decision",
          "route": "docs/decisions/"
        },
        {
          "pressure": "ecosystem doctrine",
          "route": "Agents-of-Abyss"
        }
      ],
      "stop_lines": [
        "Do not mutate repo state through this pack.",
        "Do not treat topology inspection as proof that a change is ready to land."
      ],
      "source_path": "agents/operating-model/capabilities/packs/topology-readonly.capability.json"
    }
  ]
}
